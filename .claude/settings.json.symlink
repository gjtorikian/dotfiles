{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/gjtorikian/.dotfiles/.claude/hooks/fix-env-lazy-load.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/gjtorikian/.dotfiles/.claude/hooks/track-start-time.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/gjtorikian/.dotfiles/.claude/hooks/sounds-on-task-complete.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/Users/gjtorikian/.dotfiles/bin/claude-status"
  },
  "enabledPlugins": {
    "ralph-loop@claude-plugins-official": true,
    "ideation@nicknisi": true,
    "spec-driven@nicknisi": true,
    "consultant@nicknisi": true,
    "skill-creator@claude-plugins-official": true,
    "content@nicknisi": true,
    "gopls-lsp@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "agents@gjtorikian-plugins": true,
    "github@gjtorikian-plugins": true,
    "git@gjtorikian-plugins": true
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true
}
